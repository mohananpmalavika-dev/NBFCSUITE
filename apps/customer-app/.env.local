# Local Development - Microservice URLs
# Use this for local docker-compose development (port 8001-8018)

# API Gateway (when running nginx - use this when available)
# NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080

# Individual Microservice URLs (Local Docker Compose)
