# Production/Render Environment - API Gateway Routing
# All microservices are accessed through a single API Gateway

# ========================================
# PRODUCTION CONFIGURATION
# ========================================

# API Gateway URL (single entry point for all services)
# Replace with your actual Render API Gateway URL
# Example: https://api-gateway-yourapp.onrender.com
# The API Gateway will route:
#   /auth/*        → auth-service
#   /los/*         → los-service
#   /hrms/*        → hrms-service
#   ... (all 19 services)
NEXT_PUBLIC_API_GATEWAY_URL=https://api-gateway-yourapp.onrender.com

# ========================================
# OPTIONAL: Individual Service URLs
# (Commented out - only needed if NOT using API Gateway)
# ========================================

# Uncomment these if API Gateway is not available
# or if you want direct service access

NEXT_PUBLIC_ACCOUNTING_API_URL=https://nbfc-accounts.onrender.com
NEXT_PUBLIC_AUTH_API_URL=https://nbfc-auth.onrender.com
# NEXT_PUBLIC_LOS_API_URL=https://los-service-yourapp.onrender.com
# NEXT_PUBLIC_LMS_API_URL=https://lms-service-yourapp.onrender.com
# NEXT_PUBLIC_COLLECTIONS_API_URL=https://collections-service-yourapp.onrender.com
# NEXT_PUBLIC_CUSTOMER_API_URL=https://customer-service-yourapp.onrender.com
# NEXT_PUBLIC_FINDNA_API_URL=https://findna-service-yourapp.onrender.com
# NEXT_PUBLIC_DEPOSITS_API_URL=https://deposits-service-yourapp.onrender.com
# NEXT_PUBLIC_ACCOUNTING_API_URL=https://accounting-service-yourapp.onrender.com
# NEXT_PUBLIC_CRM_API_URL=https://crm-service-yourapp.onrender.com
# NEXT_PUBLIC_DOCUMENT_API_URL=https://document-service-yourapp.onrender.com
# NEXT_PUBLIC_COMPLIANCE_API_URL=https://compliance-service-yourapp.onrender.com
# NEXT_PUBLIC_HRMS_API_URL=https://hrms-service-yourapp.onrender.com
# NEXT_PUBLIC_GOLD_API_URL=https://gold-service-yourapp.onrender.com
# NEXT_PUBLIC_TREASURY_API_URL=https://treasury-service-yourapp.onrender.com
# NEXT_PUBLIC_WEALTH_API_URL=https://wealth-service-yourapp.onrender.com
# NEXT_PUBLIC_INSURANCE_API_URL=https://insurance-service-yourapp.onrender.com
# NEXT_PUBLIC_PROCUREMENT_API_URL=https://procurement-service-yourapp.onrender.com
# NEXT_PUBLIC_PLATFORM_API_URL=https://platform-service-yourapp.onrender.com
# NEXT_PUBLIC_NOTIFICATIONS_API_URL=https://notifications-service-yourapp.onrender.com

# ========================================
# HOW TO SET UP ON RENDER
# ========================================
# 
# 1. Deploy API Gateway (Nginx):
#    - Service Name: api-gateway
#    - Dockerfile: infra/nginx/Dockerfile
#    - Port: 8080
#    - URL: https://api-gateway-yourapp.onrender.com (auto-generated)
#    - No environment variables needed
#
# 2. Deploy all 19 backend services:
#    - Each with their own Render service
#    - Connected via internal networking (Render private IPs)
#    - All expose port 8000 internally
#    - Nginx routes to them internally
#
# 3. Deploy Frontend to Vercel:
#    - Set NEXT_PUBLIC_API_GATEWAY_URL to your Render API Gateway URL
#    - Frontend will call API Gateway instead of individual services
#    - API Gateway routes to backend services
#
# ========================================
