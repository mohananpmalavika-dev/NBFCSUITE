# Deposit Service Environment Variables

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/nbfc_deposits

# Service URLs
CUSTOMER_SERVICE_URL=http://customer-service:8001
ACCOUNTING_SERVICE_URL=http://accounting-service:8003
DOCUMENT_SERVICE_URL=http://document-service:8006

# Application
SERVICE_NAME=deposit-os
SERVICE_PORT=8007
LOG_LEVEL=INFO

# Features
ENABLE_AI_FEATURES=true
ENABLE_AUTO_RENEWAL=true
ENABLE_PREMATURE_CLOSURE=true

# Security
JWT_SECRET=your-secret-key-here
API_KEY=your-api-key-here
