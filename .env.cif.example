# =============================================================================
# CIF/Customer 360 - Environment Configuration
# =============================================================================
# Copy this file to .env and update with your actual credentials
# DO NOT commit .env file with real credentials to version control

# =============================================================================
# CREDIT BUREAU CONFIGURATION
# =============================================================================

# Mock Mode - Set to 'false' for production with real bureau APIs
BUREAU_USE_MOCK=true

# CIBIL (TransUnion) Configuration
# Register at: https://www.cibil.com/
CIBIL_API_KEY=your_cibil_api_key_here
CIBIL_API_SECRET=your_cibil_api_secret_here
CIBIL_API_URL=https://api.cibil.com
# Cost per pull: ₹15-25 (approximate)

# Equifax Configuration
# Register at: https://www.equifax.co.in/
EQUIFAX_API_KEY=your_equifax_api_key_here
EQUIFAX_API_SECRET=your_equifax_api_secret_here
EQUIFAX_API_URL=https://api.equifax.co.in
# Cost per pull: ₹15-25 (approximate)

# Experian Configuration
# Register at: https://www.experian.in/
EXPERIAN_API_KEY=your_experian_api_key_here
EXPERIAN_API_SECRET=your_experian_api_secret_here
EXPERIAN_API_URL=https://api.experian.in
# Cost per pull: ₹15-25 (approximate)

# CRIF High Mark Configuration
# Register at: https://www.crifhighmark.com/
CRIF_API_KEY=your_crif_api_key_here
CRIF_API_SECRET=your_crif_api_secret_here
CRIF_API_URL=https://api.crifhighmark.com
# Cost per pull: ₹15-25 (approximate)

# =============================================================================
# eKYC / AADHAAR CONFIGURATION
# =============================================================================

# Mock Mode - Set to 'false' for production with real UIDAI APIs
EKYC_USE_MOCK=true

# UIDAI (Aadhaar) eKYC Configuration
# Register at: https://portal.uidai.gov.in/
# Requires KUA (KYC User Agency) or ASA (Authentication Service Agency) license
UIDAI_API_KEY=your_uidai_api_key_here
UIDAI_API_SECRET=your_uidai_api_secret_here
UIDAI_API_URL=https://ekyc.uidai.gov.in/api

# UIDAI Environment
# Options: 'production', 'preprod', 'staging'
UIDAI_ENVIRONMENT=preprod

# UIDAI License Details
UIDAI_LICENSE_KEY=your_kua_license_key_here
UIDAI_SUB_AUA_CODE=your_sub_aua_code_here

# Cost per transaction:
# - OTP-based eKYC: ₹1-2 per transaction
# - Biometric eKYC: ₹3-5 per transaction

# =============================================================================
# DIGILOCKER CONFIGURATION
# =============================================================================

# Mock Mode - Set to 'false' for production with real DigiLocker APIs
DIGILOCKER_USE_MOCK=true

# DigiLocker OAuth Configuration
# Register at: https://partners.digitallocker.gov.in/
DIGILOCKER_CLIENT_ID=your_digilocker_client_id_here
DIGILOCKER_CLIENT_SECRET=your_digilocker_client_secret_here
DIGILOCKER_API_URL=https://api.digitallocker.gov.in

# DigiLocker Redirect URIs (comma-separated for multiple)
# Must match exactly with registered URIs
DIGILOCKER_REDIRECT_URIS=https://yourapp.com/callback,https://localhost:3000/callback

# DigiLocker Environment
# Options: 'production', 'staging'
DIGILOCKER_ENVIRONMENT=staging

# Cost: Free for government documents

# =============================================================================
# FILE STORAGE CONFIGURATION (for documents from DigiLocker)
# =============================================================================

# Storage Provider: 's3', 'minio', 'azure', 'local'
STORAGE_PROVIDER=minio

# MinIO/S3 Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_NAME=customer-documents
MINIO_USE_SSL=false

# AWS S3 Configuration (if using S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=customer-documents

# =============================================================================
# SECURITY & ENCRYPTION
# =============================================================================

# Encryption key for sensitive data (Aadhaar, biometric)
# Generate with: openssl rand -hex 32
DATA_ENCRYPTION_KEY=your_32_byte_encryption_key_here

# JWT Secret for API authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# =============================================================================
# API RATE LIMITING
# =============================================================================

# Rate limit for bureau APIs (per customer per hour)
BUREAU_RATE_LIMIT_PER_HOUR=10

# Rate limit for eKYC OTP (per Aadhaar per hour)
EKYC_OTP_RATE_LIMIT_PER_HOUR=5

# Rate limit for DigiLocker (per customer per minute)
DIGILOCKER_RATE_LIMIT_PER_MINUTE=20

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable detailed API logging
API_LOGGING_ENABLED=true

# Enable timeline auto-logging for customer operations
TIMELINE_AUTO_LOGGING=true

# =============================================================================
# COMPLIANCE & CONSENT
# =============================================================================

# Require explicit consent before bureau pull
REQUIRE_BUREAU_CONSENT=true

# Require explicit consent before eKYC
REQUIRE_EKYC_CONSENT=true

# Require explicit consent before DigiLocker access
REQUIRE_DIGILOCKER_CONSENT=true

# Consent retention period (in months)
CONSENT_RETENTION_MONTHS=60

# =============================================================================
# NOTIFICATION SETTINGS (for eKYC OTP, etc.)
# =============================================================================

# SMS Provider for OTP
SMS_PROVIDER=twilio
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=YOURAPP

# Email Provider
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your_email_api_key
EMAIL_FROM=noreply@yourcompany.com

# =============================================================================
# TESTING & DEVELOPMENT
# =============================================================================

# Test Mode - Use test/sandbox environments
TEST_MODE=true

# Test Aadhaar Numbers (for UAT/Staging)
# UIDAI provides test Aadhaar numbers for testing
TEST_AADHAAR_NUMBERS=999999990019,999999990028

# Mock OTP for testing (when EKYC_USE_MOCK=true)
MOCK_OTP=123456

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Connection
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nbfcsuite
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (for caching & rate limiting)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your_redis_password

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable specific features
FEATURE_CREDIT_BUREAU=true
FEATURE_EKYC=true
FEATURE_DIGILOCKER=true
FEATURE_CUSTOMER_TIMELINE=true
FEATURE_BIOMETRIC_VERIFICATION=false

# =============================================================================
# WEBHOOK CONFIGURATION (Future)
# =============================================================================

# Webhook endpoints for async notifications
WEBHOOK_BUREAU_COMPLETE=https://yourapp.com/webhooks/bureau-complete
WEBHOOK_EKYC_COMPLETE=https://yourapp.com/webhooks/ekyc-complete
WEBHOOK_DOCUMENT_VERIFIED=https://yourapp.com/webhooks/document-verified

# Webhook secret for signature verification
WEBHOOK_SECRET=your_webhook_secret_here

# =============================================================================
# PRODUCTION CHECKLIST
# =============================================================================
# Before going to production:
# 
# 1. Set all *_USE_MOCK to false
# 2. Update all API keys with production credentials
# 3. Set TEST_MODE to false
# 4. Configure proper storage (S3/MinIO)
# 5. Set up proper encryption keys
# 6. Enable rate limiting in production
# 7. Set up monitoring and alerting
# 8. Configure proper logging
# 9. Set up backup for encryption keys
# 10. Test all integrations in preprod/staging first
# 11. Set LOG_LEVEL to WARNING or ERROR
# 12. Enable all compliance features (consent tracking)
# 13. Set up proper SSL certificates
# 14. Configure firewall rules
# 15. Set up proper database backups
# =============================================================================

# =============================================================================
# SUPPORT & DOCUMENTATION
# =============================================================================
