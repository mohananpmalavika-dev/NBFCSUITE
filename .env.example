# NBFC Suite - Environment Configuration Template
# Copy this file to .env and update with your actual values

# ============================================
# APPLICATION
# ============================================
APP_NAME=NBFC Financial Suite
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://nbfc_admin:nbfc_secure_2026@localhost:5432/nbfc_suite
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nbfc_suite
DB_USER=nbfc_admin
DB_PASSWORD=nbfc_secure_2026
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://:nbfc_redis_2026@localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=nbfc_redis_2026
REDIS_DB=0

# ============================================
# RABBITMQ
# ============================================
RABBITMQ_URL=amqp://nbfc_admin:nbfc_rabbit_2026@localhost:5672/
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=nbfc_admin
RABBITMQ_PASSWORD=nbfc_rabbit_2026
RABBITMQ_VHOST=/

# ============================================
# MINIO (S3-compatible storage)
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=nbfc_admin
MINIO_SECRET_KEY=nbfc_minio_2026
MINIO_BUCKET=nbfc-documents
MINIO_SECURE=false

# ============================================
# ELASTICSEARCH
# ============================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=nbfc

# ============================================
# SECURITY
# ============================================
SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_SECRET_KEY=change-this-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=change-this-32-byte-encryption-key

# ============================================
# MULTI-TENANT
# ============================================
DEFAULT_TENANT_ID=default
TENANT_ISOLATION_ENABLED=true

# ============================================
# EMAIL
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@nbfcsuite.com
SMTP_FROM_NAME=NBFC Suite

# ============================================
# SMS
# ============================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# WHATSAPP
# ============================================
WHATSAPP_PROVIDER=twilio
WHATSAPP_PHONE_NUMBER=+1234567890

# ============================================
# AADHAAR eKYC
# ============================================
AADHAAR_API_URL=https://api.uidai.gov.in
AADHAAR_CLIENT_ID=your-client-id
AADHAAR_CLIENT_SECRET=your-client-secret
AADHAAR_CERTIFICATE_PATH=/path/to/certificate.pem

# ============================================
# CREDIT BUREAUS
# ============================================
# CIBIL
CIBIL_API_URL=https://api.cibil.com
CIBIL_USER_ID=your-cibil-user-id
CIBIL_PASSWORD=your-cibil-password
CIBIL_MEMBER_CODE=your-member-code

# Equifax
EQUIFAX_API_URL=https://api.equifax.com
EQUIFAX_API_KEY=your-equifax-api-key

# Experian
EXPERIAN_API_URL=https://api.experian.com
EXPERIAN_CLIENT_ID=your-experian-client-id
EXPERIAN_CLIENT_SECRET=your-experian-client-secret

# CRIF
CRIF_API_URL=https://api.crif.com
CRIF_USER_ID=your-crif-user-id
CRIF_PASSWORD=your-crif-password

# ============================================
# PAYMENT GATEWAY
# ============================================
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ============================================
# UPI
# ============================================
UPI_PROVIDER=npci
NPCI_API_URL=https://api.npci.org.in
NPCI_MERCHANT_ID=your-merchant-id
NPCI_MERCHANT_KEY=your-merchant-key

# ============================================
# DIGILOCKER
# ============================================
DIGILOCKER_CLIENT_ID=your-digilocker-client-id
DIGILOCKER_CLIENT_SECRET=your-digilocker-client-secret
DIGILOCKER_REDIRECT_URI=http://localhost:8000/api/v1/auth/digilocker/callback

# ============================================
# OCR & AI SERVICES
# ============================================
# AWS Textract
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Google Vision API
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json

# OpenAI (for AI assistant)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
# Sentry
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Jaeger (Distributed Tracing)
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_WORKFLOW_ENGINE=true
FEATURE_RULES_ENGINE=true
FEATURE_DECISION_ENGINE=true
FEATURE_FRAUD_DETECTION=true
FEATURE_AI_ASSISTANT=false
FEATURE_MULTI_TENANT=true

# ============================================
# DEVELOPMENT
# ============================================
LOG_LEVEL=DEBUG
LOG_FORMAT=json
ENABLE_SWAGGER=true
ENABLE_REDOC=true
