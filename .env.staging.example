# ============================================
# NBFC Financial Suite - Staging Environment
# ============================================

# Application
APP_NAME=NBFC Financial Suite
APP_ENV=staging
APP_DEBUG=false

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nbfc_staging
DB_USER=nbfc_user
DB_PASSWORD=CHANGE_THIS_PASSWORD

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_PASSWORD

# Security
SECRET_KEY=CHANGE_THIS_SECRET_KEY_MINIMUM_32_CHARACTERS
JWT_SECRET_KEY=CHANGE_THIS_JWT_SECRET_KEY_MINIMUM_32_CHARACTERS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,https://staging.yourdomain.com
CORS_ALLOW_CREDENTIALS=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Email (SMTP Configuration)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# File Upload
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=10

# Logging
LOG_LEVEL=INFO

# Multi-tenancy
TENANT_ISOLATION_ENABLED=true
DEFAULT_TENANT=default

# API Documentation
ENABLE_SWAGGER=true
ENABLE_REDOC=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Session
SESSION_TIMEOUT_MINUTES=30
